@import url('https://fonts.googleapis.com/css2?family=Yuji+Syuku&display=swap');
 /* 共通の背景設定 */
.app-background {
  position: fixed;
  inset: 0;
  background: url(<%= asset_path 'app-background.png' %>) center/cover no-repeat;
  z-index: -1;
}

/* gameの基本画面設定 */
/* === pkフィールド全体 === */
/* ゴール全体のフレーム（高さは比率で決める） */
/* pk-field をサイズコンテナ化（高さベースの単位 cqh を使う） */
.pk-field{
  container-type: size;   /* ← inline-size から size に変更 */
  position: relative;
  width: min(92vw, 680px);
  aspect-ratio: 16 / 12;
  max-height: 70dvh;
  margin: 0 auto;
  overflow: hidden;
}

/* ゴール画像：枠いっぱいに “収める”（切らない） */
.pk-field .goal{
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: contain;
  z-index: 1;
  pointer-events: none;
}

/* ─ キーパー（絶対配置で左右に動かす） ─ */
/* キーパー：高さをゴール高の70%に固定（左右移動は従来通り） */
.pk-field .keeper{
  position: absolute;
  bottom: 0;
  left: 50%; transform: translateX(-50%);
  height: 70%;           /* ← ゴール高の70% */
  width: auto;
  object-fit: contain;
  pointer-events: none;
  z-index: 2;
}
/* ─ 左右のポジション（シュート3分割と揃える） ─ */
/* 画面を 3 等分：中心座標を 1/6, 3/6, 5/6 に置くとちょうど良い */
.pk-field .keeper.left   { left: 16.6667%; transform: translateX(-50%); }
.pk-field .keeper.center { left: 50%;      transform: translateX(-50%); }
.pk-field .keeper.right  { left: 83.3333%; transform: translateX(-50%); }

/* 端末向きで器だけ微調整（キーパーは再定義しない！） */
@media (orientation: portrait){
  .pk-field{ width: 92vw; max-height: 70dvh; }
}
@media (orientation: landscape){
  .pk-field{ width: min(80vw, 960px); max-height: 80dvh; }
}

/* シュートゾーン（タップ領域は広めに） */
/* ３択の設定（z-index最前面にする） */
.shoot-zone {
  position: absolute;
  bottom: 12%;      /* ← ゴール枠に近い高さ */
  height: 30%;      /* ← 高さを明示的に制御 */
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 5;
}
.shoot-zone.left   { left: 0; width: 33.33%; }
.shoot-zone.center { left: 33.33%; width: 33.34%; }
.shoot-zone.right  { left: 66.67%; width: 33.33%; }

.shoot-btn-circle {
  width: 100%; height: 100%;
  background: transparent;
  border: none;
  cursor: pointer;
}

/* 結果画面の設定：蹴った位置にボールを残す */
/* シュートボタン内のボール：ゴール高の7%（= キーパー高の10%） */
.shoot-btn-circle{
  display:flex; align-items:center; justify-content:center;
}
.shoot-btn-circle .shoot-ball{
  width: clamp(16px, 5cqh, 36px);  /* 最小/最大を保険で。中央値はゴール高の7% */
  height: auto;
  pointer-events: none;
}

.ball-position {
  position: absolute; bottom: 12%; height: 30%;
  display: flex;
  align-items: center;     /* ←縦中央揃え */
  justify-content: center; /* ←横中央揃え */
  z-index: 5;
}
.ball-position.left   { left: 0; width: 33.33%; }
.ball-position.center { left: 33.33%; width: 33.34%; }
.ball-position.right  { left: 66.67%; width: 33.33%; }

/* === index上のpkのミニスタッツで現在のゴール率を表示 === */
.pk-mini-stats{
  position: fixed;
  left: 50%;
  bottom: 12px;
  transform: translateX(-50%);
  z-index: 10000;
  padding: 16px 32px;
  font-size: 24px;
  line-height: 1;
  color: #fff;
  background: rgba(0,0,0,.55);
  backdrop-filter: blur(6px);
  border-radius: 9999px;
  pointer-events: none;
  display: flex; gap: 10px; align-items: center;
}
.pk-mini-stats__link{
  color: #fff;
  text-decoration: underline;
  pointer-events: auto;         /* リンクだけクリック可 */
}

@media (max-width: 480px){
  .pk-mini-stats{ font-size: 11px; padding: 5px 10px; bottom: 8px; }
}

/* --- Stats summaryのレウアウト --- */
.stats-summary{
  width: min(92vw, 800px);
  margin: 12px auto 16px;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 8px;
}
.stats-summary .stat{
  background: #f4f4f5; border: 1px solid #e5e7eb; border-radius: 10px;
  padding: 8px 10px; text-align: center;
}
.stats-summary .stat span{ display:block; font-size:12px; color:#6b7280; }
.stats-summary .stat strong{ font-size:18px; }

/* --- Table書式設定 --- */
.table-wrap{ width: min(92vw, 800px); margin: 0 auto; }
.pk-table{ width:100%; border-collapse: collapse; font-size:14px; }
.pk-table thead th{
  position: sticky; top: 0;
  background:#111827; color:#fff; text-align:left; padding:10px 8px;
}
.pk-table td, .pk-table th{ border-bottom:1px solid #e5e7eb; padding:10px 8px; }
.pk-table tbody tr:nth-child(odd){ background:#fafafa; }

/* 状態バッジ */
.badge{display:inline-block; padding:4px 8px; border-radius:9999px; font-weight:700;}
.badge-goal{ background:#dcfce7; color:#166534; }
.badge-save{ background:#fee2e2; color:#991b1b; }

/* 先頭文字だけ大文字（left/center/right → Left...） */
.cap{ text-transform: capitalize; }

/* --- モバイルで“カード風”に自動変形（読みやすさ重視） --- */
@media (max-width: 640px){
  .stats-summary{ grid-template-columns: repeat(3, 1fr); }
  .pk-table thead{ display:none; }
  .pk-table, .pk-table tbody, .pk-table tr, .pk-table td{ display:block; width:100%; }
  .pk-table tr{ margin-bottom:10px; border:1px solid #e5e7eb; border-radius:12px; overflow:hidden; background:#fff; }
  .pk-table td{
    border-bottom:1px solid #f3f4f6; padding:8px 12px; position:relative;
  }
  .pk-table td:last-child{ border-bottom:none; }
  .pk-table td::before{
    content: attr(data-label);
    position:absolute; left:12px; top:8px; font-size:12px; color:#6b7280;
  }
  .pk-table td{ padding-top:24px; }
}

/* --- 戻るボタンを画面に固定配置 --- */
.back-to-pk-btn {
  position: fixed;
  bottom: 20px;       /* 画面下から20px */
  right: 20px;        /* 画面右から20px */
  background: #111827;
  color: #fff;
  padding: 10px 16px;
  border-radius: 9999px;
  font-weight: bold;
  text-decoration: none;
  box-shadow: 0 2px 6px rgba(0,0,0,0.25);
  z-index: 10000;
  transition: background 0.2s;
}

.back-to-pk-btn:hover {
  background: #1f2937;  /* hoverで少し明るく */
}

/* === ✨季節感の演出✨ === */
/* === 🍂Falling leaves🍂 === */
.falling-layer {
  pointer-events: none;
  position: fixed;
  left: 0; top: 0;
  width: 100vw; height: 100vh;
  overflow: hidden;
  z-index: 9999;
}
.leaf {
  position: absolute; top: -10vh;
  animation: leaf-fall 8s linear infinite;
  opacity: 0.9;
  filter: drop-shadow(0 2px 2px rgba(0,0,0,.15));
}
@keyframes leaf-fall {
  0%   { transform: translateY(-10vh) rotate(0deg);   opacity: 0; }
  10%  { opacity: 1; }
  100% { transform: translateY(110vh) rotate(360deg); opacity: 0.95; }
}

/* === 連続ゴール・フローティングバナー === */
.streak-banner{
  position: fixed;
  top: 45px;
  left: 25%;
  transform: translateX(-50%);
  z-index: 10001;             /* 🍁季節演出(9999) より前面に */
  display: inline-flex; gap: 8px; flex-wrap: wrap;
  background: rgba(17,24,39,.85);
  color: #fff; padding: 8px 12px; border-radius: 9999px;
  font-weight: 700; box-shadow: 0 4px 10px rgba(0,0,0,.15);
}

.streak-banner .chip{
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 10px; border-radius: 9999px; line-height: 1;
  background: rgba(255,255,255,.08);
}
.streak-banner .chip strong{ font-size: 1.05em; }

.chip-current{ background: rgba(34,197,94,.18); } /* 緑っぽく */
.chip-max    { background: rgba(244,63,94,.18); } /* 赤っぽく */

@keyframes streak-pop {
  0% { transform: translateX(-50%) scale(.8); opacity: 0; }
  100% { transform: translateX(-50%) scale(1); opacity: 1; }
}
@keyframes streak-pulse {
  0%,100% { transform: translateX(-50%) scale(1); }
  50%     { transform: translateX(-50%) scale(1.06); }
}

/* === セーブ時：ゴール枠をガタガタ揺らす === */
@keyframes shake {
  0% { transform: translateX(0); }
  25% { transform: translateX(-6px); }
  50% { transform: translateX(6px); }
  75% { transform: translateX(-4px); }
  100% { transform: translateX(0); }
}
.shake { animation: shake .8s ease; }

/* === 連続ゴールが止まった時：バナーを警告色で点滅 === */
@keyframes streak-break {
  0%,100% { background: rgba(255, 0, 0, .90); }
  50%     { background: rgba(139, 0, 0, .90); }
}
.streak-banner.break { animation: streak-break .6s ease-in-out 3; }

/* === Buttons ===================================== */
.btn {
  --btn-bg: linear-gradient(135deg, #2563eb 0%, #10b981 100%);
  --btn-bg-hover: linear-gradient(135deg, #1d4ed8 0%, #059669 100%);
  --btn-shadow: 0 8px 20px rgba(16, 185, 129, .35);
  display: inline-flex; align-items: center; gap: 8px;
  padding: 12px 18px; border-radius: 9999px;
  background: var(--btn-bg);
  color: #fff; font-weight: 800; letter-spacing: .03em;
  text-decoration: none; border: none; cursor: pointer;
  box-shadow: var(--btn-shadow);
  transform: translateY(0);
  transition: transform .12s ease, filter .2s ease, box-shadow .2s ease, background .2s ease;
}
.btn:hover { background: var(--btn-bg-hover); filter: brightness(1.02); box-shadow: 0 10px 24px rgba(16,185,129,.45); }
.btn:active { transform: translateY(1px); filter: brightness(.98); }

/* 主ボタン：ゲスト用（目立つ色） */
.btn--primary{
  background: #0ea5e9;        /* sky-500 */
  color: #fff;
  box-shadow: 0 8px 18px rgba(14,165,233,.25);
}
.btn--primary:hover{ background:#0284c7; }
.btn--primary:active{ transform: translateY(2px) scale(.99); }

/* 従ボタン：（色やさしめ） */
.btn--secondary{
  margin-top:8px;
  background: rgba(255,255,255,.8);
  color: #0f172a;              /* slate-900 */
  border: 2px solid rgba(15,23,42,.15);
  box-shadow: 0 4px 14px rgba(0,0,0,.06);
}
.btn--secondary:hover{
  background:#fff; border-color: rgba(15,23,42,.25);
}
.btn--secondary:active{ transform: translateY(1px) scale(.99); }
.btn--ghost {
  background: rgba(17, 24, 39, .65);
  backdrop-filter: blur(6px);
  box-shadow: 0 6px 18px rgba(0,0,0,.25);
}
.btn--danger {
  --btn-bg: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
  --btn-bg-hover: linear-gradient(135deg, #dc2626 0%, #991b1b 100%);
  --btn-shadow: 0 8px 20px rgba(239, 68, 68, .35);
}

@media (prefers-reduced-motion: reduce){
  .btn { transition: none; }
  .falling-layer, .streak-banner.break {
    animation: none;
    transition: none;
  }
}

/* === Hero（見出しの装飾） ======================== */
.hero {
  width: min(92vw, 900px);
  margin: 20px auto 12px;
  text-align: center;
}

/* 筆字っぽいフォント */
@import url('https://fonts.googleapis.com/css2?family=Yuji+Syuku&family=Shippori+Mincho&display=swap');

.hero-title {
  font-family: 'Yuji Syuku', serif;
  font-size: clamp(28px, 5vw, 52px);
  font-weight: 900;
  letter-spacing: .05em;
  color: #111827;
}

.hero-sub {
  font-family: 'Yuji Syuku', serif;
  font-size: clamp(18px, 3vw, 22px);
  color: #374151;
  margin-top: 8px;
}
/* === （どこに蹴る？のフォント設定） ======================== */
.kick-prompt {
  font-family: 'Yuji Syuku', serif;
  font-size: clamp(22px, 3.5vw, 28px);
  font-weight: 700;
  letter-spacing: .05em;
  color: #111827;
  text-align: center;
  margin-bottom: 12px;
}

/* === （BGM設定） ======================== */
.bgm-toggle{
  position: fixed; right: 16px; bottom: 76px; /* 戻るボタンとかぶらない位置 */
  z-index: 10002;
  background: rgba(9, 47, 130, 0.85); color:#fff; border:none;
  padding: 8px 12px; border-radius: 9999px; font-weight: 700;
  box-shadow: 0 4px 10px rgba(21, 54, 223, 0.2); cursor: pointer;
}

/* === （footer_copyrights） ======================== */
.site-footer{
  width: 100%; text-align: center; padding: 16px 8px; margin-top: 40px;
  color:#6b7280; font-size: 12px;
}

/* === （X_posts） ======================== */
.action-buttons{
  display:flex; flex-direction:column; gap:8px; align-items:center; justify-content:center;
}

/* ================================
  Fusuma Animation
================================ */

.fusuma-overlay {
  position: fixed;
  inset: 0;
  z-index: 20000;
  display: flex;
  overflow: hidden;
  pointer-events: none;
  background: rgba(20, 16, 10, 0.10);
}

.fusuma-panel {
  position: relative;
  width: 50%;
  height: 100%;
  flex-shrink: 0;
  transition: transform 0.95s cubic-bezier(.77,0,.175,1);
}

.fusuma-inner {
  position: absolute;
  inset: 0;
  box-sizing: border-box;

  /* 和紙っぽい下地 + 陰影 */
  background:
    linear-gradient(to bottom, rgba(255,255,255,0.22), rgba(0,0,0,0.04)),
    radial-gradient(circle at 30% 20%, rgba(255,255,255,0.20), transparent 35%),
    linear-gradient(to top, rgba(120, 120, 120, 0.08), transparent 25%),
    #c9b191;

  border: 14px solid #3b2d24;
  box-shadow:
    inset 0 0 0 1px rgba(255,255,255,0.15),
    inset 0 0 18px rgba(0,0,0,0.08);
}

/* 真ん中の合わせ目を少し細く */
.fusuma-left .fusuma-inner {
  border-right-width: 5px;
}

.fusuma-right .fusuma-inner {
  border-left-width: 5px;
}

/* 襖の丸引手 */
.fusuma-handle {
  position: absolute;
  top: 50%;
  width: 22px;
  height: 22px;
  transform: translateY(-50%);
  border-radius: 50%;
  background:
    radial-gradient(circle at 35% 35%, #6c5a4c, #3d3027 75%);
  box-shadow:
    inset 0 1px 2px rgba(255,255,255,0.2),
    0 1px 2px rgba(0,0,0,0.18);
}

.fusuma-left .fusuma-handle {
  right: 26px;
}

.fusuma-right .fusuma-handle {
  left: 26px;
}

/* 上部のしめ縄風の装飾 */
.fusuma-inner::before {
  content: "";
  position: absolute;
  top: 28px;
  left: 8%;
  width: 84%;
  height: 8px;
  border-radius: 999px;
  background:
    repeating-linear-gradient(
      45deg,
      #9d8a78 0 8px,
      #c8bbab 8px 16px
    );
  opacity: 0.8;
}

/* 垂れ飾りっぽい房 */
.fusuma-inner::after {
  content: "";
  position: absolute;
  top: 38px;
  left: 50%;
  width: 14px;
  height: 64px;
  transform: translateX(-50%);
  background:
    linear-gradient(to bottom, #d8d0c5 0 20px, #c5b6a2 20px 24px, #d8d0c5 24px 100%);
  clip-path: polygon(35% 0, 65% 0, 70% 18%, 100% 100%, 0 100%, 30% 18%);
  opacity: 0.55;
}

/* 左右の竹っぽい意匠 */
.fusuma-left .fusuma-inner .fusuma-handle::before,
.fusuma-right .fusuma-inner .fusuma-handle::before {
  content: "";
  position: absolute;
  width: 88px;
  height: 140px;
  top: -120px;
  opacity: 0.18;
  background:
    linear-gradient(135deg, transparent 30%, #4f5f45 30% 34%, transparent 34%),
    linear-gradient(110deg, transparent 45%, #4f5f45 45% 49%, transparent 49%),
    linear-gradient(145deg, transparent 56%, #4f5f45 56% 60%, transparent 60%);
}

.fusuma-left .fusuma-inner .fusuma-handle::before {
  right: -36px;
}

.fusuma-right .fusuma-inner .fusuma-handle::before {
  left: -36px;
  transform: scaleX(-1);
}

/* 下部の山影 */
.fusuma-panel::before {
  content: "";
  position: absolute;
  left: 10%;
  right: 10%;
  bottom: 6%;
  height: 18%;
  background:
    radial-gradient(circle at 20% 80%, rgba(120,120,120,0.18), transparent 45%),
    radial-gradient(circle at 55% 75%, rgba(120,120,120,0.16), transparent 42%),
    radial-gradient(circle at 82% 82%, rgba(120,120,120,0.18), transparent 44%);
  opacity: 0.7;
  pointer-events: none;
}

/* タイトル */
.fusuma-title {
  position: absolute;
  inset: 0;
  display: grid;
  place-items: center;
  font-family: 'Yuji Syuku', serif;
  font-size: clamp(42px, 8vw, 86px);
  letter-spacing: 0.08em;
  color: #1b1b1b;   /* 墨色 */
  text-shadow:
    0 2px 6px rgba(0,0,0,0.22),
    0 0 18px rgba(255,255,255,0.08);
  opacity: 0;
  transform: translateY(120px) scale(0.98);
  transition:
    opacity 0.28s ease,
    transform 0.28s ease;
}

/* タイトル表示 */
.fusuma-overlay.show-title .fusuma-title {
  opacity: 1;
  transform: translateY(45px) scale(1);
}

/* タイトル非表示 */
.fusuma-overlay.hide-title .fusuma-title {
  opacity: 0;
  transform: translateY(45px) scale(0.95);
}

/* 開く */
.fusuma-overlay.is-open .fusuma-left {
  transform: translateX(-100%);
}

.fusuma-overlay.is-open .fusuma-right {
  transform: translateX(100%);
}

@media (prefers-reduced-motion: reduce) {
  .fusuma-panel,
  .fusuma-title {
    transition: none;
  }
}
